{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./**/credentials*)",
      "Read(./**/.ssh/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Write(./archive/**)",
      "Edit(./archive/**)"
    ]
  }
}
